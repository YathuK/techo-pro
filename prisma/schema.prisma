generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String   @unique
  password    String
  name        String
  companyName String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers      Customer[]
  employees      Employee[]
  jobs           Job[]
  quotes         Quote[]
  invoices       Invoice[]
  inventoryItems InventoryItem[]
  messages       Message[]
}

model Customer {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String?
  phone     String?
  address   String?
  status    String   @default("Lead")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobs     Job[]
  quotes   Quote[]
  invoices Invoice[]
  messages Message[]
}

model Employee {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String?
  phone          String?
  role           String
  team           String?
  status         String   @default("Available")
  rating         Float    @default(0)
  hoursPerWeek   Float    @default(0)
  certifications String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobIds String[] @db.ObjectId
  jobs   Job[]    @relation(fields: [jobIds], references: [id])
}

model Job {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  jobNumber String
  type      String
  address   String?
  status    String    @default("Quote Sent")
  value     Float     @default(0)
  startDate DateTime?
  endDate   DateTime?
  progress  Int       @default(0)
  materials String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  crewIds  String[]  @db.ObjectId
  crew     Employee[] @relation(fields: [crewIds], references: [id])
  invoices Invoice[]
}

model Quote {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  quoteNumber String
  project     String
  value       Float     @default(0)
  status      String    @default("Draft")
  content     String?
  aiGenerated Boolean   @default(false)
  validUntil  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String
  project       String?
  amount        Float     @default(0)
  paid          Float     @default(0)
  status        String    @default("Draft")
  dueDate       DateTime?
  sentDate      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  jobId String? @db.ObjectId
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)
}

model InventoryItem {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  category     String
  unit         String
  inStock      Float    @default(0)
  reorderPoint Float    @default(0)
  price        Float    @default(0)
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  template  String?
  subject   String?
  content   String
  status    String   @default("draft")
  createdAt DateTime @default(now())

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}
